    function view_corrigendums(id,document_type) { // Declare a function registration_number
        //$('#LoadingDiv').show();
        $.ajax({
            type: "POST",
            url: "https://haryanarera.gov.in/assistancecontrol/view_corrigendums_popup",
            data: {project_id: btoa(id),document_type: document_type},
            dataType:'json',
            cache: false,
            success: function(data){
                $('#LoadingDiv').hide();
                    $("#view_corrigendums").modal({
                        backdrop: 'static',
                        keyboard: false
                    });
                $('#corrigendums_registration_certificate_no').html(data.registration_certificate_no);
                $('#corrigendums_project_name').html(data.project_name);
                var x = 1;
                $('#corrigendum_list').html('');
                data.corrigendum_list.forEach(function(value) {
                    var document_type = value.document_for;
                    if (document_type == 'C')
                    {
                        document_type  = 'Corrigendum/Addendum';
                    }
                    else if (document_type == 'EXT')
                    {
                        document_type  = 'Extension';
                    }
                    else if (document_type == 'OC')
                    {
                        document_type  = 'Occupation Certificate';
                    }
                    else if (document_type == 'PCC')
                    {
                        document_type  = 'Part Completion Certificate';
                    } else if (document_type == 'CC')
                    {
                        document_type  = 'Completion Certificate';
                    } else if (document_type == 'cancel_order')
                    {
                        document_type  = 'Cancel Order';
                    }else if (document_type == 'sale_ban')
                    {
                        document_type  = 'Sale Ban';
                    }
                    var  domElement = $('<tr><td>' + x + '</td><td>' + document_type + '</td><td>' + value.remarks + '</td> <td><a href="https://haryanarera.gov.in/assistancecontrol/view_corrigendum/' + btoa(value.id) + '" target="_blank">View</a></td></tr>');
                    $('#corrigendum_list').append(domElement);
                    x++;
                });
            }
        });
    }

</script></body></html>