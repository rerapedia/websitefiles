    function changetab(evt, tabName) {
        var i, tabcontent, tablinks;
        tabcontent = document.getElementsByClassName("tabcontent");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].style.display = "none";
        }
        tablinks = document.getElementsByClassName("tablinks");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].className = tablinks[i].className.replace(" active", "");
        }
        document.getElementById(tabName).style.display = "block";
        evt.currentTarget.className += " active";
    }

    // Get the element with id="defaultOpen" and click on it
    //document.getElementById("defaultOpen").click();
    $('.toggle_sidebar').on('click', function () {
        $('.cus-sidebar').toggleClass('close');
        // $('.main-page1').addClass('main-page');
        if ($(".cus-left-content").hasClass("main-page")) {
            $('.cus-left-content').removeClass('main-page');
        }else{
            $('.cus-left-content').addClass('main-page');

        }
        if ($(".toggle_sidebar").hasClass("fa-arrow-circle-o-right")) {
            $('.toggle_sidebar').removeClass('fa-arrow-circle-o-right');
            $('.toggle_sidebar').addClass('fa-arrow-circle-o-left');
        }else{
            $('.toggle_sidebar').removeClass('fa-arrow-circle-o-left');
            $('.toggle_sidebar').addClass('fa-arrow-circle-o-right');
        }
    });
    $( "#navbar_toggle" ).click(function() {
        if($('#bs-example-navbar-collapse-1').is(':visible')) {
            $('#bs-example-navbar-collapse-1').css('display','none');
            $('#bs-example-navbar-collapse-2').css('display','block');
        } else {
            $('#bs-example-navbar-collapse-1').css('display','block');
            $('#bs-example-navbar-collapse-2').css('display','none');
        }
    });
    var affectedElements = $("div,p,span,h1,h3,table,tr,td,th,body,blockquote,i,h4,h5,h6,label,legend,footer,a,img,section,ol,ul,li,em,button,small,textarea"); // Can be extended, ex. $("div, p, span.someClass")

    // Storing the original size in a data attribute so size can be reset
    affectedElements.each( function(){
        $(this).data("orig-size", $(this).css("font-size") );
    });

    $("#btn-increase").click(function(){
        changeFontSize(1);
    });

    $("#btn-decrease").click(function(){
        changeFontSize(-1);
    });

    $("#btn-orig").click(function(){
        affectedElements.each( function(){
            $(this).css( "font-size" , $(this).data("orig-size") );
        });
    });

    function changeFontSize(direction){
        affectedElements.each( function(){
            $(this).css( "font-size" , parseInt($(this).css("font-size"))+direction );
        });
    }
