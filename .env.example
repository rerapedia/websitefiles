# GharScore Production Environment Variables
# Copy this to .env.local and fill in all values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/gharscore?schema=public
DIRECT_URL=postgresql://user:pass@host:5432/gharscore

# Search (Meilisearch)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_admin_key

# Site URL
NEXT_PUBLIC_SITE_URL=https://gharscore.in

# Authentication (NextAuth)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://gharscore.in

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=re_xxxxx

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx

# Cron Security
CRON_SECRET=generate_random_secret

# Error Tracking (Sentry)
SENTRY_DSN=

# Analytics
POSTHOG_KEY=
GA_MEASUREMENT_ID=

# WhatsApp Bot (Twilio - optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
